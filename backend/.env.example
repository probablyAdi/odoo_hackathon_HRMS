# Copy this file to .env and fill in real values. Never commit .env itself.

DATABASE_URL=postgresql://hrms_user:hrms_pass@localhost:5432/hrms

# Generate a strong random value for production, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS - the origin(s) your frontend is served from
FRONTEND_ORIGIN=http://localhost:5500
